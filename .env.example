# ============================================================
# Docket environment configuration
# Copy to `.env` and adjust. All keys are read via os.Getenv.
# ============================================================

# --- Application ---
DOCKET_PORT=8080
DOCKET_API_KEY=dev-secret-change-me
LOG_LEVEL=info

# --- Postgres (records: users, audit log) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=docket
POSTGRES_PASSWORD=docket
POSTGRES_DB=docket
POSTGRES_SSLMODE=disable

# --- MongoDB (metadata: tags, descriptions, flexible fields) ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=docket

# --- NATS JetStream (events: upload/delete notifications) ---
NATS_URL=nats://nats:4222
NATS_STREAM=DOCKET_EVENTS
NATS_SUBJECT_PREFIX=docket.files

# --- Redis (cache: view counters, rate limits) ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO S3 (object storage: file bytes) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docket
MINIO_USE_SSL=false

# --- OpenTelemetry tracing ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=docket
OTEL_TRACES_SAMPLER=always_on
